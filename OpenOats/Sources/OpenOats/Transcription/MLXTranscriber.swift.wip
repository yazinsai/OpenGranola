import Foundation
import MLX
import MLXAudioSTT
import os

enum MLXTranscriberError: Error {
    case modelNotLoaded
}

/// Thread-safe wrapper around `Qwen3ASRModel` for MLX-based speech-to-text.
/// A single instance is shared between mic and system audio transcription;
/// the actor serializes concurrent calls.
actor MLXTranscriber {
    private var model: Qwen3ASRModel?
    private let log = Logger(subsystem: "com.openoats", category: "MLXTranscriber")

    private static let hubModelID = "mlx-community/Qwen3-ASR-1.7B-8bit"

    func loadModel() async throws {
        log.info("Loading MLX Qwen3 ASR 1.7B model...")
        let loaded = try await Qwen3ASRModel.fromPretrained(Self.hubModelID)
        self.model = loaded
        log.info("MLX Qwen3 ASR 1.7B model loaded successfully")
    }

    func transcribe(audioSamples: [Float], language: String) async throws -> String {
        guard let model else {
            throw MLXTranscriberError.modelNotLoaded
        }

        let audioArray = MLXArray(audioSamples)
        let params = STTGenerateParameters(language: language)
        let output = model.generate(audio: audioArray, generationParameters: params)
        return output.text
    }

    /// Check whether the HuggingFace Hub cache already contains the model files.
    static func modelExists() -> Bool {
        let cacheDir = FileManager.default.homeDirectoryForCurrentUser
            .appendingPathComponent(".cache/huggingface/hub")
        let modelDir = cacheDir.appendingPathComponent(
            "models--\(hubModelID.replacingOccurrences(of: "/", with: "--"))"
        )
        return FileManager.default.fileExists(atPath: modelDir.path)
    }
}
